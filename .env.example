# ───────────── Database (Postgres) ─────────────
# Vercel: set to your Vercel Postgres / Neon / Supabase pooled connection string.
# Local dev: a free Neon / Supabase DB works, or run Postgres locally.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ───────────── NextAuth ─────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-32+-char-string"
# Locally: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ───────────── WHOOP OAuth ─────────────
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
# Must match the redirect URI registered in your WHOOP developer dashboard
WHOOP_REDIRECT_URI="http://localhost:3000/api/whoop/callback"
