datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String?
  sex            String?   // "male" | "female"
  bodyWeightKg   Float?
  heightCm       Float?
  dateOfBirth    DateTime?
  preferredUnits String    @default("imperial") // "metric" | "imperial"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workouts         Workout[]
  bodyMeasurements BodyMeasurement[]
  whoopConnection  WhoopConnection?
  whoopData        WhoopDatum[]
  customExercises  Exercise[]       @relation("CustomExercises")
}

model Workout {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @default(now())
  name            String?
  notes           String?
  durationMin     Int?
  // WHOOP fields
  whoopActivityId String?   @unique
  strainScore     Float?
  avgHeartRate    Float?
  maxHeartRate    Float?
  calories        Float?
  activityType    String?   // from WHOOP activity type
  isDetailed      Boolean   @default(false) // true when user has added exercise data
  createdAt       DateTime  @default(now())

  user      User              @relation(fields: [userId], references: [id])
  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String @id @default(cuid())
  workoutId  String
  exerciseId String
  order      Int    @default(0)

  workout  Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise      @relation(fields: [exerciseId], references: [id])
  sets     ExerciseSet[]
}

model ExerciseSet {
  id                String   @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  weightKg          Float
  reps              Int
  rpe               Float?   // Rate of Perceived Exertion 1-10
  isWarmup          Boolean  @default(false)
  createdAt         DateTime @default(now())

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
}

model Exercise {
  id                 String  @id @default(cuid())
  name               String  @unique
  category           String  // "compound" | "isolation"
  equipment          String? // "barbell" | "dumbbell" | "cable" | "machine" | "bodyweight"
  primaryMuscles     String  // comma-separated muscle slugs
  secondaryMuscles   String? // comma-separated muscle slugs
  isStrengthStandard Boolean @default(false)
  isCustom           Boolean @default(false)
  createdByUserId    String?
  linkedExerciseId   String? // links a custom exercise to a standard one for tracking

  createdByUser     User?     @relation("CustomExercises", fields: [createdByUserId], references: [id])
  linkedExercise    Exercise? @relation("ExerciseLinks", fields: [linkedExerciseId], references: [id])
  linkedFrom        Exercise[] @relation("ExerciseLinks")
  workoutExercises  WorkoutExercise[]
  strengthStandards StrengthStandard[]
}

model StrengthStandard {
  id           String @id @default(cuid())
  exerciseId   String
  sex          String // "male" | "female"
  bodyWeightKg Float
  beginner     Float  // 1RM in kg
  novice       Float
  intermediate Float
  advanced     Float
  elite        Float

  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([exerciseId, sex, bodyWeightKg])
}

model BodyMeasurement {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @default(now())
  weightKg   Float
  bodyFatPct Float?
  phase      String?  // "cut" | "bulk" | "maintain"
  notes      String?
  calories   Int?     // total daily calories
  proteinG   Float?   // grams
  carbsG     Float?   // grams
  fatG       Float?   // grams

  user User @relation(fields: [userId], references: [id])
}

model WhoopConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  whoopUserId  String?
  scopes       String   // comma-separated
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model WhoopDatum {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime
  dataType         String   // "recovery" | "strain" | "sleep"
  recoveryScore    Float?   // 0-100
  hrvRmssd         Float?   // ms
  restingHr        Float?   // bpm
  strainScore      Float?   // 0-21
  sleepDurationMs  Int?
  sleepPerformance Float?
  sleepEfficiency  Float?
  spo2             Float?
  skinTempC        Float?
  rawJson          String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, dataType])
}
